// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  
  accounts  Account[]
  healthScores HealthScoreSnapshot[]
}

model Account {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // bank, stock, mf, crypto, gold, loan, credit_card
  name      String
  balance   Float
  currency  String   @default("INR")

  transactions Transaction[]
  holdings     Holding[]
}

model Transaction {
  id         String   @id @default(uuid())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date       DateTime
  amount     Float
  category   String
  merchant   String
  type       String   // debit, credit
}

model Holding {
  id           String   @id @default(uuid())
  accountId    String
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol       String
  quantity     Float
  avgPrice     Float
  currentPrice Float
  assetClass   String
}

model HealthScoreSnapshot {
  id                    String   @id @default(uuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date                  DateTime @default(now())
  savingsRate           Float
  emergencyFundMonths   Float
  diversificationScore  Float
  debtRatio             Float
  liquidityScore        Float
  overallScore          Float
}
